{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:openplantrace:schema:benchmark-comparison:v1",
  "title": "OpenPlanTrace Benchmark Comparison",
  "description": "Schema for OpenPlanTrace benchmark comparison results. It compares two benchmark result JSON files and records deterministic regression, improvement, and informational signals. It does not represent AI output.",
  "type": "object",
  "additionalProperties": true,
  "x-openplantrace-schemaVersion": "openplantrace.benchmark-comparison.v1",
  "required": [
    "schemaVersion",
    "generatedAt",
    "baselineCaseCount",
    "candidateCaseCount",
    "matchedCaseCount",
    "addedCaseCount",
    "removedCaseCount",
    "regressionCount",
    "improvementCount",
    "cases",
    "signals"
  ],
  "properties": {
    "schemaVersion": {
      "const": "openplantrace.benchmark-comparison.v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "baselineName": {
      "$ref": "#/$defs/nullableString"
    },
    "candidateName": {
      "$ref": "#/$defs/nullableString"
    },
    "baselineCaseCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "candidateCaseCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "matchedCaseCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "addedCaseCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "removedCaseCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "regressionCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "improvementCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/caseComparison"
      }
    },
    "signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signal"
      }
    },
    "passed": {
      "type": "boolean"
    }
  },
  "$defs": {
    "caseComparison": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "fixtureId",
        "status",
        "countDeltas",
        "signals"
      ],
      "properties": {
        "fixtureId": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/caseStatus"
        },
        "baselineName": {
          "$ref": "#/$defs/nullableString"
        },
        "candidateName": {
          "$ref": "#/$defs/nullableString"
        },
        "baselinePassed": {
          "$ref": "#/$defs/nullableBoolean"
        },
        "candidatePassed": {
          "$ref": "#/$defs/nullableBoolean"
        },
        "baselineSkipped": {
          "type": "boolean"
        },
        "candidateSkipped": {
          "type": "boolean"
        },
        "baselineSkipReason": {
          "$ref": "#/$defs/nullableString"
        },
        "candidateSkipReason": {
          "$ref": "#/$defs/nullableString"
        },
        "baselineDurationMilliseconds": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "candidateDurationMilliseconds": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "durationDeltaMilliseconds": {
          "$ref": "#/$defs/nullableNumber"
        },
        "baselineQualityGrade": {
          "$ref": "#/$defs/nullableQualityGrade"
        },
        "candidateQualityGrade": {
          "$ref": "#/$defs/nullableQualityGrade"
        },
        "baselineQualityConfidence": {
          "$ref": "#/$defs/nullableConfidence"
        },
        "candidateQualityConfidence": {
          "$ref": "#/$defs/nullableConfidence"
        },
        "baselinePassedAssertionCount": {
          "$ref": "#/$defs/nullableNonNegativeInteger"
        },
        "candidatePassedAssertionCount": {
          "$ref": "#/$defs/nullableNonNegativeInteger"
        },
        "baselineFailedAssertionCount": {
          "$ref": "#/$defs/nullableNonNegativeInteger"
        },
        "candidateFailedAssertionCount": {
          "$ref": "#/$defs/nullableNonNegativeInteger"
        },
        "countDeltas": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/countDelta"
          }
        },
        "signals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/signal"
          }
        }
      }
    },
    "caseStatus": {
      "type": "string",
      "enum": [
        "Matched",
        "Added",
        "Removed"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "countDelta": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "baseline": {
          "$ref": "#/$defs/nullableNonNegativeInteger"
        },
        "candidate": {
          "$ref": "#/$defs/nullableNonNegativeInteger"
        },
        "delta": {
          "$ref": "#/$defs/nullableInteger"
        }
      }
    },
    "nullableBoolean": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "nullableConfidence": {
      "anyOf": [
        {
          "$ref": "#/$defs/confidence"
        },
        {
          "type": "null"
        }
      ]
    },
    "nullableInteger": {
      "type": [
        "integer",
        "null"
      ]
    },
    "nullableNonNegativeInteger": {
      "anyOf": [
        {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        {
          "type": "null"
        }
      ]
    },
    "nullableNonNegativeNumber": {
      "anyOf": [
        {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        {
          "type": "null"
        }
      ]
    },
    "nullableNumber": {
      "type": [
        "number",
        "null"
      ]
    },
    "nullableQualityGrade": {
      "anyOf": [
        {
          "$ref": "#/$defs/qualityGrade"
        },
        {
          "type": "null"
        }
      ]
    },
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "nonNegativeNumber": {
      "type": "number",
      "minimum": 0
    },
    "qualityGrade": {
      "type": "string",
      "enum": [
        "Unknown",
        "Poor",
        "ReviewRequired",
        "Usable",
        "Strong"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "Info",
        "Improvement",
        "Regression"
      ]
    },
    "signal": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "fixtureId",
        "code",
        "severity",
        "message"
      ],
      "properties": {
        "fixtureId": {
          "type": "string",
          "minLength": 1
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "baseline": {
          "$ref": "#/$defs/nullableString"
        },
        "candidate": {
          "$ref": "#/$defs/nullableString"
        }
      }
    }
  }
}
