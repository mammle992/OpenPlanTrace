{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:openplantrace:schema:benchmark-result:v1",
  "title": "OpenPlanTrace Benchmark Result",
  "description": "Schema for OpenPlanTrace benchmark run results. Results record deterministic fixture outcomes, detector metrics, scan-quality counts, and readiness scoreboard data. They do not represent AI output.",
  "type": "object",
  "additionalProperties": true,
  "x-openplantrace-schemaVersion": "openplantrace.benchmark-result.v1",
  "required": [
    "schemaVersion",
    "generatedAt",
    "cases",
    "scoreboard",
    "reviewQueue",
    "caseCount",
    "reviewQueueCount",
    "passedCaseCount",
    "failedCaseCount",
    "skippedCaseCount",
    "passedAssertionCount",
    "failedAssertionCount",
    "passed"
  ],
  "properties": {
    "schemaVersion": {
      "const": "openplantrace.benchmark-result.v1"
    },
    "name": {
      "$ref": "#/$defs/nullableString"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/caseResult"
      }
    },
    "scoreboard": {
      "$ref": "#/$defs/scoreboard"
    },
    "reviewQueue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reviewQueueItem"
      }
    },
    "caseCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "reviewQueueCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "passedCaseCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "failedCaseCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "skippedCaseCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "passedAssertionCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "failedAssertionCount": {
      "$ref": "#/$defs/nonNegativeInteger"
    },
    "passed": {
      "type": "boolean"
    }
  },
  "$defs": {
    "assertion": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name",
        "passed",
        "expected",
        "actual",
        "message"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "passed": {
          "type": "boolean"
        },
        "expected": {
          "type": "string"
        },
        "actual": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "caseResult": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "fixtureId",
        "sourcePath",
        "passed",
        "scanSucceeded",
        "durationMilliseconds",
        "counts",
        "assertions",
        "metrics",
        "qualityIssues",
        "diagnosticIssues",
        "planIssues",
        "stages",
        "artifactInventory",
        "artifactPlans",
        "executionWaves",
        "rerunImpacts",
        "rerunPlans",
        "pipelineHealth",
        "importReadiness",
        "passedAssertionCount",
        "failedAssertionCount"
      ],
      "properties": {
        "fixtureId": {
          "type": "string",
          "minLength": 1
        },
        "fixtureName": {
          "$ref": "#/$defs/nullableString"
        },
        "sourcePath": {
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "scanSucceeded": {
          "type": "boolean"
        },
        "durationMilliseconds": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "counts": {
          "$ref": "#/$defs/counts"
        },
        "assertions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/assertion"
          }
        },
        "errorMessage": {
          "$ref": "#/$defs/nullableString"
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/detectorMetric"
          }
        },
        "qualityIssues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/caseIssueSummary"
          }
        },
        "diagnosticIssues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/caseIssueSummary"
          }
        },
        "planIssues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pipelinePlanIssueSummary"
          }
        },
        "stages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stageSummary"
          }
        },
        "artifactInventory": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactSnapshot"
          }
        },
        "artifactPlans": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactPlanSummary"
          }
        },
        "executionWaves": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/executionWaveSummary"
          }
        },
        "rerunImpacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rerunImpactSummary"
          }
        },
        "rerunPlans": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rerunPlanSummary"
          }
        },
        "pipelineHealth": {
          "$ref": "#/$defs/pipelineHealthSummary"
        },
        "importReadiness": {
          "$ref": "#/$defs/importReadiness"
        },
        "wallPlacement": {
          "$ref": "#/$defs/wallPlacementSummary"
        },
        "scanReviewQueue": {
          "$ref": "#/$defs/scanReviewQueueSummary"
        },
        "skipped": {
          "type": "boolean"
        },
        "skipReason": {
          "$ref": "#/$defs/nullableString"
        },
        "passedAssertionCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "failedAssertionCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      }
    },
    "executionWaveSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "level",
        "stageCount",
        "stages",
        "reads",
        "writes",
        "directDownstreamStages",
        "directDownstreamStageCount",
        "downstreamReadArtifacts",
        "writeConflictArtifacts",
        "intraWaveDependencyCount",
        "hasWriteConflicts",
        "hasIntraWaveDependencies",
        "isParallelCandidate",
        "parallelReadiness",
        "schedulingReasons",
        "recommendedExecutionMode"
      ],
      "properties": {
        "level": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "stageCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "stages": {
          "$ref": "#/$defs/stringArray"
        },
        "reads": {
          "$ref": "#/$defs/stringArray"
        },
        "writes": {
          "$ref": "#/$defs/stringArray"
        },
        "directDownstreamStages": {
          "$ref": "#/$defs/stringArray"
        },
        "directDownstreamStageCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "downstreamReadArtifacts": {
          "$ref": "#/$defs/stringArray"
        },
        "writeConflictArtifacts": {
          "$ref": "#/$defs/stringArray"
        },
        "intraWaveDependencyCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "hasWriteConflicts": {
          "type": "boolean"
        },
        "hasIntraWaveDependencies": {
          "type": "boolean"
        },
        "isParallelCandidate": {
          "type": "boolean"
        },
        "parallelReadiness": {
          "type": "string"
        },
        "schedulingReasons": {
          "$ref": "#/$defs/stringArray"
        },
        "recommendedExecutionMode": {
          "type": "string"
        }
      }
    },
    "artifactPlanSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "artifact",
        "isSourceArtifact",
        "isProducedByStage",
        "isConsumedByStage",
        "isTerminalArtifact",
        "producerStages",
        "requiredConsumerStages",
        "optionalConsumerStages",
        "consumerStages",
        "producerCount",
        "consumerCount",
        "firstProducerWave",
        "lastProducerWave",
        "firstConsumerWave",
        "lastConsumerWave",
        "hasMultipleProducers",
        "hasRequiredConsumers",
        "dependencyRole",
        "evidence"
      ],
      "properties": {
        "artifact": {
          "type": "string"
        },
        "isSourceArtifact": {
          "type": "boolean"
        },
        "isProducedByStage": {
          "type": "boolean"
        },
        "isConsumedByStage": {
          "type": "boolean"
        },
        "isTerminalArtifact": {
          "type": "boolean"
        },
        "producerStages": {
          "$ref": "#/$defs/stringArray"
        },
        "requiredConsumerStages": {
          "$ref": "#/$defs/stringArray"
        },
        "optionalConsumerStages": {
          "$ref": "#/$defs/stringArray"
        },
        "consumerStages": {
          "$ref": "#/$defs/stringArray"
        },
        "producerCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "consumerCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "firstProducerWave": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "lastProducerWave": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "firstConsumerWave": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "lastConsumerWave": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "hasMultipleProducers": {
          "type": "boolean"
        },
        "hasRequiredConsumers": {
          "type": "boolean"
        },
        "dependencyRole": {
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "pipelinePlanIssueSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "code",
        "severity",
        "stage",
        "artifacts",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string"
        },
        "stage": {
          "type": "string"
        },
        "artifacts": {
          "$ref": "#/$defs/stringArray"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "rerunImpactSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "artifact",
        "isSourceArtifact",
        "impactScope",
        "producerStages",
        "directConsumerStages",
        "affectedStages",
        "affectedArtifacts",
        "firstAffectedWave",
        "affectedStageCount",
        "hasImpact",
        "evidence"
      ],
      "properties": {
        "artifact": {
          "type": "string"
        },
        "isSourceArtifact": {
          "type": "boolean"
        },
        "impactScope": {
          "type": "string"
        },
        "producerStages": {
          "$ref": "#/$defs/stringArray"
        },
        "directConsumerStages": {
          "$ref": "#/$defs/stringArray"
        },
        "affectedStages": {
          "$ref": "#/$defs/stringArray"
        },
        "affectedArtifacts": {
          "$ref": "#/$defs/stringArray"
        },
        "firstAffectedWave": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "affectedStageCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "hasImpact": {
          "type": "boolean"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "rerunPlanSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "planId",
        "displayName",
        "changedArtifacts",
        "changedSourceArtifacts",
        "directConsumerStages",
        "rerunStages",
        "rerunWaves",
        "affectedArtifacts",
        "firstRerunWave",
        "lastRerunWave",
        "rerunStageCount",
        "affectedArtifactCount",
        "hasWork",
        "recommendedExecutionMode",
        "evidence"
      ],
      "properties": {
        "planId": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string"
        },
        "changedArtifacts": {
          "$ref": "#/$defs/stringArray"
        },
        "changedSourceArtifacts": {
          "$ref": "#/$defs/stringArray"
        },
        "directConsumerStages": {
          "$ref": "#/$defs/stringArray"
        },
        "rerunStages": {
          "$ref": "#/$defs/stringArray"
        },
        "rerunWaves": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonNegativeInteger"
          }
        },
        "affectedArtifacts": {
          "$ref": "#/$defs/stringArray"
        },
        "firstRerunWave": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "lastRerunWave": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "rerunStageCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "affectedArtifactCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "hasWork": {
          "type": "boolean"
        },
        "recommendedExecutionMode": {
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "pipelineHealthSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "dependencyReady",
        "planIssueCount",
        "planWarningCount",
        "planErrorCount",
        "stageCount",
        "dependencyReadyStageCount",
        "notDependencyReadyStageCount",
        "missingRequiredReadCount",
        "missingOptionalReadCount",
        "runtimeRequiredReadsHaveData",
        "runtimeOptionalReadsHaveData",
        "emptyRequiredRuntimeReadCount",
        "emptyOptionalRuntimeReadCount",
        "writesOnlyDeclaredArtifacts",
        "contractViolationStageCount",
        "undeclaredChangedArtifactCount",
        "emptyDeclaredOutputCount",
        "reviewStageNames",
        "evidence"
      ],
      "properties": {
        "dependencyReady": {
          "type": "boolean"
        },
        "planIssueCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "planWarningCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "planErrorCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "stageCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "dependencyReadyStageCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "notDependencyReadyStageCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "missingRequiredReadCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "missingOptionalReadCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "runtimeRequiredReadsHaveData": {
          "type": "boolean"
        },
        "runtimeOptionalReadsHaveData": {
          "type": "boolean"
        },
        "emptyRequiredRuntimeReadCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "emptyOptionalRuntimeReadCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "writesOnlyDeclaredArtifacts": {
          "type": "boolean"
        },
        "contractViolationStageCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "undeclaredChangedArtifactCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "emptyDeclaredOutputCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "reviewStageNames": {
          "$ref": "#/$defs/stringArray"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "scanReviewQueueSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "count",
        "kindCounts",
        "severityCounts"
      ],
      "properties": {
        "count": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "kindCounts": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/nonNegativeInteger"
          }
        },
        "severityCounts": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/nonNegativeInteger"
          }
        }
      }
    },
    "wallPlacementSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "totalWallCount",
        "placementReadyWallCount",
        "placementReviewWallCount",
        "rejectedNoiseWallCount",
        "acceptedWallCount",
        "reviewDecisionWallCount",
        "rejectedWallCount",
        "structuralComponentCount",
        "mainStructuralComponentCount",
        "secondaryStructuralComponentCount",
        "objectLikeComponentCount",
        "isolatedFragmentComponentCount",
        "topologyEdgeCount",
        "repairCandidateCount",
        "topologyImportBlockedRepairCandidateCount",
        "endpointGapRepairCandidateCount",
        "endpointOverrunRepairCandidateCount",
        "highSeverityRepairCandidateCount"
      ],
      "properties": {
        "totalWallCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "placementReadyWallCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "placementReviewWallCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "rejectedNoiseWallCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "acceptedWallCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "reviewDecisionWallCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "rejectedWallCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "structuralComponentCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "mainStructuralComponentCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "secondaryStructuralComponentCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "objectLikeComponentCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "isolatedFragmentComponentCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "topologyEdgeCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "repairCandidateCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "topologyImportBlockedRepairCandidateCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "endpointGapRepairCandidateCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "endpointOverrunRepairCandidateCount": { "$ref": "#/$defs/nonNegativeInteger" },
        "highSeverityRepairCandidateCount": { "$ref": "#/$defs/nonNegativeInteger" }
      }
    },
    "caseIssueSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "code",
        "severity",
        "stage",
        "scope",
        "count",
        "message",
        "pageNumbers",
        "maxConfidence",
        "sourcePrimitiveCount",
        "sourcePrimitiveIds",
        "properties"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/diagnosticSeverity"
        },
        "stage": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "count": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "message": {
          "type": "string"
        },
        "pageNumbers": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "maxConfidence": {
          "anyOf": [
            { "$ref": "#/$defs/confidence" },
            { "type": "null" }
          ]
        },
        "sourcePrimitiveCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "sourcePrimitiveIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "caseScore": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "fixtureId",
        "grade",
        "overallScore",
        "targetF1",
        "targetRecall",
        "targetPrecision",
        "assertionReliability",
        "scanQualityScore",
        "measurementScore",
        "importReadinessScore",
        "pipelineHealthScore",
        "readyForGeometryImport",
        "readyForMetricImport",
        "readyForRoutingImport",
        "pipelineHealthReady",
        "pipelineHealthIssueCount",
        "expectedTargetCount",
        "matchedTargetCount",
        "missedTargetCount",
        "extraDetectionCount",
        "failedAssertionCount",
        "qualityGrade",
        "qualityConfidence",
        "requiresReview",
        "skipped",
        "blockingReasons"
      ],
      "properties": {
        "fixtureId": {
          "type": "string",
          "minLength": 1
        },
        "grade": {
          "$ref": "#/$defs/scoreGrade"
        },
        "overallScore": {
          "$ref": "#/$defs/confidence"
        },
        "targetF1": {
          "$ref": "#/$defs/confidence"
        },
        "targetRecall": {
          "$ref": "#/$defs/confidence"
        },
        "targetPrecision": {
          "$ref": "#/$defs/confidence"
        },
        "assertionReliability": {
          "$ref": "#/$defs/confidence"
        },
        "scanQualityScore": {
          "$ref": "#/$defs/confidence"
        },
        "measurementScore": {
          "$ref": "#/$defs/confidence"
        },
        "importReadinessScore": {
          "$ref": "#/$defs/confidence"
        },
        "pipelineHealthScore": {
          "$ref": "#/$defs/confidence"
        },
        "readyForGeometryImport": {
          "type": "boolean"
        },
        "readyForMetricImport": {
          "type": "boolean"
        },
        "readyForRoutingImport": {
          "type": "boolean"
        },
        "pipelineHealthReady": {
          "type": "boolean"
        },
        "pipelineHealthIssueCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "expectedTargetCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "matchedTargetCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "missedTargetCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "extraDetectionCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "failedAssertionCount": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "qualityGrade": {
          "$ref": "#/$defs/qualityGrade"
        },
        "qualityConfidence": {
          "$ref": "#/$defs/confidence"
        },
        "requiresReview": {
          "type": "boolean"
        },
        "skipped": {
          "type": "boolean"
        },
        "blockingReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "importReadiness": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "grade",
        "score",
        "readyForGeometryImport",
        "readyForMetricImport",
        "readyForRoutingImport",
        "requiresReview",
        "blockingIssueCodes",
        "reviewIssueCodes",
        "recommendedActions",
        "evidence"
      ],
      "properties": {
        "grade": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "$ref": "#/$defs/confidence"
        },
        "readyForGeometryImport": {
          "type": "boolean"
        },
        "readyForMetricImport": {
          "type": "boolean"
        },
        "readyForRoutingImport": {
          "type": "boolean"
        },
        "requiresReview": {
          "type": "boolean"
        },
        "blockingIssueCodes": {
